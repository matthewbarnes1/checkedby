<%- include('partials/head', { pageTitle: 'Post work' }) %>
<div class="wrap" style="max-width:760px; padding-top:46px; padding-bottom:80px">
  <div class="kicker">Post work</div>
  <h2 class="title">Get your AI-generated work verified</h2>
  <p class="lead" style="font-size:.98rem">Your bounty is held in escrow and only released when you accept the completed review. Balance: <b><%= fmtMoney(user.balance_cents) %></b></p>
  <div class="panel">
    <% if (error) { %><div class="error" style="margin-bottom:16px"><%= error %></div><% } %>
    <form class="stack" method="post" action="/jobs/new">
      <div><label class="f">Job title</label><input type="text" name="title" required maxlength="140" placeholder="Fact-check our AI-drafted investor one-pager"></div>
      <div>
        <label class="f">Category</label>
        <select name="category" required>
          <% for (const [key, c] of Object.entries(CATEGORIES)) { %><option value="<%= key %>"><%= c.label %></option><% } %>
        </select>
        <div class="hint">The category determines the mandatory verification checklist the reviewer must complete.</div>
      </div>
      <div><label class="f">The AI-generated content</label><textarea name="content_text" required minlength="40" placeholder="Paste the full text, code, or document content here…"></textarea>
      <div class="hint">A SHA-256 fingerprint of exactly this content is stored on the certificate, making later edits detectable.</div></div>
      <div><label class="f">Which AI tool produced it? <span style="color:var(--mist);font-weight:400">(optional)</span></label><input type="text" name="ai_tool" maxlength="80" placeholder="ChatGPT, Claude, Gemini, Copilot…"></div>
      <div><label class="f">Instructions for the reviewer <span style="color:var(--mist);font-weight:400">(optional)</span></label><textarea name="instructions" style="min-height:80px" placeholder="What worries you most? What must be true before you ship this?"></textarea></div>
      <div><label class="f">Bounty (USD)</label><input type="number" name="bounty" min="5" max="500" step="0.01" value="25" required>
      <div class="hint">$5–$500. Typical: $15–$40 for copy, $40–$120 for code or research. Reviewer receives 85%.</div></div>
      <button class="btn" type="submit">Post &amp; fund from balance</button>
    </form>
  </div>
</div>
<%- include('partials/foot') %>
